<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>On Shelf</title>

  <!-- Bootstrap / Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css"/>
  <link rel="icon" href="/images/storage.png" sizes="32x32"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css"/>

  <link rel="stylesheet" href="/css/styles.css"/>

  <style>
    /* ===== Machine Type Pills ===== */
    .mt-pills { display: flex; flex-wrap: wrap; gap: 8px; }
    .mt-pill input[type="checkbox"] { display: none; }
    .mt-pill label {
      display: inline-block;
      padding: 6px 14px;
      border: 1.5px solid #6c757d;
      border-radius: 999px;
      font-size: 0.85rem;
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
      transition: background .15s, color .15s, border-color .15s;
    }
    .mt-pill input:checked + label {
      background: #0d6efd;
      color: #fff;
      border-color: #0d6efd;
    }

    /* ===== Cards ===== */
    .product-card .card { border-radius: 12px; overflow: hidden; }
    .card-img-top.fixed-size { width: 100%; height: 160px; object-fit: contain; background: #f8f9fa; }

    /* ===== Pagination — นิ้วกดได้ง่ายขึ้น ===== */
    .pagination .page-link {
      min-width: 44px;
      min-height: 44px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1rem;
    }

    /* ===== Filter switches ===== */
    .form-check-input { width: 2.5em; height: 1.4em; }
  </style>
</head>
<body>

<div class="container-fluid">
  <div class="row">

    <div class="desktop-sidebar col-lg-2 col-12 d-none d-lg-block">
      <%- include('sidebar-public') %>
    </div>
    <%- include('sidebarMobile-public') %>

    <div class="col-lg-10 col-12">

      <h2 class="text-center p-4">
        Stock on-shelf
        <img src="/images/procurement.png" alt="logo" class="img-fluid"
          style="max-width: 40px; vertical-align: middle" />
      </h2>

      <div class="container-fluid">
        <form method="get" action="/public-onhand" id="filterForm" class="mb-3">

          <!-- Search -->
          <div class="input-group mb-3">
            <input
              type="text"
              name="search"
              class="form-control form-control-lg"
              value="<%= search %>"
              placeholder="กรอก SKU หรือ Description"
              inputmode="search"
              enterkeyhint="search"
              autocomplete="off"
            />
            <button type="submit" class="btn btn-success px-4">
              <i class="bi bi-search"></i>
            </button>
          </div>

          <!-- Machine Type Pills -->
          <% if (machineTypeOptions && machineTypeOptions.length > 0) { %>
          <div class="mb-3">
            <div class="mt-pills" id="mtPills">
              <% machineTypeOptions.forEach(t => { %>
                <span class="mt-pill">
                  <input
                    type="checkbox"
                    name="machineTypes"
                    id="mt-<%= t %>"
                    value="<%= t %>"
                    <%= (Array.isArray(machineTypesSelected) && machineTypesSelected.includes(t)) ? 'checked' : '' %>
                  />
                  <label for="mt-<%= t %>"><%= t %></label>
                </span>
              <% }) %>
            </div>
          </div>
          <% } %>

          <!-- Stock Filter Switches -->
          <div class="d-flex flex-wrap gap-3 mb-2">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="hideOutOfStock" role="switch">
              <label class="form-check-label" for="hideOutOfStock">
                Hide <span class="text-danger fw-semibold">Out of Stock</span>
              </label>
            </div>
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="onlyOutOfStock" role="switch">
              <label class="form-check-label" for="onlyOutOfStock">
                Only <span class="text-danger fw-semibold">Out of Stock</span>
              </label>
            </div>
          </div>

          <input type="hidden" name="filter" id="filterInput" value="<%= filter %>">
        </form>
      </div>

      <!-- Cards — 2 คอลัมน์บนมือถือ, 3 คอลัมน์บน desktop -->
      <div class="row row-cols-2 row-cols-md-3 g-3 px-2">
        <% if (products.length > 0) { %>
          <% products.forEach(product => { %>
            <div class="col product-card">
              <div class="card h-100 card-hover">
                <%
                  // ตัด ?v=timestamp ออก ให้ CDN cache ได้
                  const imgSrc = product.image
                    ? 'https://res.cloudinary.com/dzuw4hsd7/image/upload/f_auto,q_auto,w_400/' + product.image
                    : null;
                %>
                <% if (imgSrc) { %>
                  <img
                    class="card-img-top fixed-size"
                    src="<%= imgSrc %>"
                    alt="<%= product.sku %>"
                    loading="lazy"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                <% } %>
                <div style="display:none; justify-content:center; align-items:center; height:160px;" class="text-muted">
                  <i class="fas fa-image fa-3x"></i>
                </div>

                <div class="card-body p-2 p-md-3">
                  <h6 class="card-title text-center fw-bold mb-2"><%= product.sku %></h6>
                  <p class="card-text small text-muted mb-1"><%= product.description %></p>
                  <p class="card-text small mb-1">
                    Cost: <span class="fw-semibold">
                      <%= new Intl.NumberFormat(undefined, { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(product.cost) %>
                    </span>
                  </p>
                  <p class="card-text text-end fw-bold mb-0 <%= product.quantity <= 0 ? 'text-danger' : 'text-success' %>">
                    Qty: <%= product.quantity %>
                  </p>
                </div>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="col-12">
            <div class="alert alert-warning text-center" role="alert">ไม่พบข้อมูลที่ตรงกับคำค้นหา</div>
          </div>
        <% } %>
      </div>

      <!-- Pagination -->
      <%
        const pageWindow = 2;
        let startPage = Math.max(1, current - pageWindow);
        let endPage   = Math.min(pages, current + pageWindow);
        if (current <= pageWindow)       endPage   = Math.min(pages, startPage + 4);
        if (current + pageWindow > pages) startPage = Math.max(1, pages - 4);

        const mtQuery     = (Array.isArray(machineTypesSelected) && machineTypesSelected.length)
          ? '&' + machineTypesSelected.map(mt => 'machineTypes=' + encodeURIComponent(mt)).join('&')
          : '';
        const searchQuery = search ? '&search=' + encodeURIComponent(search) : '';
        const filterQuery = (filter && filter !== 'all') ? '&filter=' + encodeURIComponent(filter) : '';
      %>
      <nav aria-label="Page navigation" class="mt-4 px-2">
        <ul class="pagination justify-content-center flex-wrap">
          <li class="page-item <%= current <= 1 ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= current - 1 %><%= searchQuery %><%= mtQuery %><%= filterQuery %>">
              <i class="bi bi-chevron-left"></i>
            </a>
          </li>

          <% if (startPage > 1) { %>
            <li class="page-item"><a class="page-link" href="?page=1<%= searchQuery %><%= mtQuery %><%= filterQuery %>">1</a></li>
            <% if (startPage > 2) { %><li class="page-item disabled"><span class="page-link">…</span></li><% } %>
          <% } %>

          <% for (let i = startPage; i <= endPage; i++) { %>
            <li class="page-item <%= current === i ? 'active' : '' %>">
              <a class="page-link" href="?page=<%= i %><%= searchQuery %><%= mtQuery %><%= filterQuery %>"><%= i %></a>
            </li>
          <% } %>

          <% if (endPage < pages) { %>
            <% if (endPage < pages - 1) { %><li class="page-item disabled"><span class="page-link">…</span></li><% } %>
            <li class="page-item"><a class="page-link" href="?page=<%= pages %><%= searchQuery %><%= mtQuery %><%= filterQuery %>"><%= pages %></a></li>
          <% } %>

          <li class="page-item <%= current >= pages ? 'disabled' : '' %>">
            <a class="page-link" href="?page=<%= current + 1 %><%= searchQuery %><%= mtQuery %><%= filterQuery %>">
              <i class="bi bi-chevron-right"></i>
            </a>
          </li>
        </ul>
        <p class="text-center text-muted small">หน้าที่ <%= current %> / <%= pages %></p>
      </nav>

    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>

<script>
window.addEventListener('DOMContentLoaded', function () {
  const form        = document.getElementById('filterForm');
  const filterInput = document.getElementById('filterInput');
  const hideSw      = document.getElementById('hideOutOfStock');
  const onlySw      = document.getElementById('onlyOutOfStock');
  const searchInput = document.querySelector('input[name="search"]');

  // โฟกัส search ถ้ามีค่าอยู่
  if (searchInput && searchInput.value) {
    searchInput.focus();
    searchInput.select();
  }

  // Restore switch state จาก filter value
  const filterVal = filterInput.value || 'all';
  if (filterVal === 'available') { hideSw.checked = true; }
  else if (filterVal === 'out')  { onlySw.checked = true; }

  function setFilterAndSubmit(val) {
    filterInput.value = val;
    form.submit();
  }

  hideSw.addEventListener('change', function () {
    if (hideSw.checked) { onlySw.checked = false; setFilterAndSubmit('available'); }
    else { setFilterAndSubmit(onlySw.checked ? 'out' : 'all'); }
  });

  onlySw.addEventListener('change', function () {
    if (onlySw.checked) { hideSw.checked = false; setFilterAndSubmit('out'); }
    else { setFilterAndSubmit(hideSw.checked ? 'available' : 'all'); }
  });

  // Pills — submit ทันทีเมื่อเลือก/ยกเลิก
  document.querySelectorAll('.mt-pill input[type="checkbox"]').forEach(function (cb) {
    cb.addEventListener('change', function () { form.submit(); });
  });
});
</script>

</body>
</html>
