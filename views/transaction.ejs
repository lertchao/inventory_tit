<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Transaction</title>

  <!-- Bootstrap -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
  <link rel="stylesheet" href="css/styles.css">
  <link rel="icon" href="images/storage.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <!-- DataTables -->
  <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/jquery.dataTables.min.css">
  <link rel="stylesheet" href="https://cdn.datatables.net/buttons/2.4.1/css/buttons.bootstrap5.min.css">
</head>
<body>

<div class="container-fluid">
  <div class="row">
    <!-- Desktop Sidebar -->
    <div class="desktop-sidebar col-lg-2 col-12 d-none d-lg-block">
      <%- include('sidebar') %>
    </div>

    <!-- Mobile Sidebar -->
    <%- include('sidebarMobile') %>

    <!-- Main Content Area -->
    <div class="col-lg-10 col-12">
      <h2 class="text-center p-4">
        Parts Transaction
        <img src="images/transaction-history.png" alt="logo" class="img-fluid"
             style="max-width: 40px; vertical-align: middle" />
      </h2>

      <div class="container-fluid">
        <!-- Date filter — server-side -->
        <form method="GET" action="/transaction" class="row g-2 mb-3 justify-content-center align-items-end">
          <div class="col-md-3 col-6">
            <label for="startDate" class="form-label">Start Date</label>
            <input type="date" id="startDate" name="startDate" class="form-control form-control-sm"
                   value="<%= startDate %>">
          </div>
          <div class="col-md-3 col-6">
            <label for="endDate" class="form-label">End Date</label>
            <input type="date" id="endDate" name="endDate" class="form-control form-control-sm"
                   value="<%= endDate %>">
          </div>
          <% if (searchQuery) { %>
            <input type="hidden" name="search" value="<%= searchQuery %>">
          <% } %>
          <div class="col-md-2 col-12 d-grid">
            <button type="submit" class="btn btn-primary btn-sm">
              <i class="bi bi-search"></i> Apply
            </button>
          </div>
        </form>


        <% if (products.length > 0) { %>
          <table id="transactionTable" class="table table-bordered table-striped display nowrap" style="width:100%">
            <thead class="table-dark">
            <tr>
              <th>SKU</th>
              <th>Description</th>
              <th class="text-center">Quantity</th>
              <th class="text-center">Transaction Type</th>
              <th class="text-center">Remaining Quantity</th>
              <th class="text-center">Requester Name</th>
              <th>Request ID</th>
              <th class="text-center">Store ID</th>
              <th>Store Name</th>
              <th>Created At</th>
            </tr>
            </thead>
            <tbody>
            <% products.forEach((transaction) => { %>
              <% transaction.products.forEach((product) => { %>
                <tr>
                  <td><%= product.sku %></td>
                  <td><%= product.description || "N/A" %></td>
                  <td class="text-center"><%= product.quantity %></td>
                  <td class="text-center">
                    <% if (transaction.transactionType === "IN") { %>
                      <span class="badge in-badge">In</span>
                    <% } else if (transaction.transactionType === "OUT") { %>
                      <span class="badge out-badge">Out</span>
                    <% } else { %>
                      <span class="badge bg-secondary">Unknown</span>
                    <% } %>
                  </td>
                  <td class="text-center"><%= product.remaining %></td>
                  <td class="text-center"><%= transaction.requesterName %></td>
                  <td><%= transaction.requestId %></td>
                  <td class="text-center"><%= transaction.storeId != null ? String(transaction.storeId).padStart(3, '0') : '-' %></td>
                  <td><%= transaction.storeName %></td>
                  <td
                    data-order="<%= transaction.createdAt.toISOString() %>"
                    data-export="<%= transaction.createdAtExcel %>">
                    <%= transaction.createdAtFormatted %>
                  </td>
                </tr>
              <% }); %>
            <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p class="text-muted">ไม่พบข้อมูลในช่วงวันที่เลือก</p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.4/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/dataTables.buttons.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.html5.min.js"></script>
<script src="https://cdn.datatables.net/buttons/2.4.1/js/buttons.print.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

<script>
  $(document).ready(function () {
    $('#transactionTable').DataTable({
      dom: "<'row mb-2'" +
        "<'col-12 col-md-6 mb-2 mb-md-0'l>" +
        "<'col-12 col-md-6 d-flex justify-content-md-end justify-content-center'B>" +
        ">" +
        "<'row mb-2'<'col-12'f>>" +
        "<'row'<'col-12'tr>>" +
        "<'row mt-2'<'col-md-6'i><'col-md-6 text-end'p>>",

      buttons: [
        {
          extend: 'csv',
          text: '<i class="bi bi-file-earmark-spreadsheet"></i> CSV',
          className: 'btn btn-outline-secondary btn-sm me-2'
        },
        {
          extend: 'excel',
          text: '<i class="bi bi-file-earmark-excel"></i> Excel',
          className: 'btn btn-outline-success btn-sm me-2',
          exportOptions: {
            format: {
              body: function (data, row, column, node) {
                if (column === 7) {
                  return $(node).attr('data-export') || data;
                }
                return $(node).text().trim();
              }
            }
          },
          customize: function (xlsx) {
            const sheet = xlsx.xl.worksheets['sheet1.xml'];
            $('row c[r^="H"]', sheet).each(function () {
              const cellRef = $(this).attr('r');
              if (cellRef === 'H1') return;
              const text = $('is t', this).text() || $('v', this).text();
              const match = text.match(/^(\d{4})-(\d{2})-(\d{2}) (\d{2}):(\d{2}):(\d{2})$/);
              if (!match) return;
              const [, y, m, d, hh, mm, ss] = match.map(Number);
              const excelDate = Date.UTC(y, m - 1, d, hh, mm, ss) / 86400000 + 25569;
              $(this).attr('t', 'n').attr('s', '67').empty().append(`<v>${excelDate}</v>`);
            });
          }
        },
        {
          extend: 'print',
          text: '<i class="bi bi-printer"></i> Print',
          className: 'btn btn-outline-primary btn-sm'
        }
      ],
      scrollX: true,
      responsive: false,
      order: [[7, 'asc']],
      pageLength: 25,
      lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, 'ทั้งหมด']],
      pagingType: "simple_numbers",
      language: {
        search: "ค้นหา:",
        lengthMenu: "แสดง _MENU_ รายการต่อหน้า",
        info: "แสดง _START_ ถึง _END_ จากทั้งหมด _TOTAL_ รายการ",
        paginate: { next: "ถัดไป", previous: "ก่อนหน้า" },
        zeroRecords: "ไม่พบข้อมูลที่ค้นหา",
        infoEmpty: "ไม่มีข้อมูลแสดง",
        infoFiltered: "(กรองจากทั้งหมด _MAX_ รายการ)"
      }
    });
  });
</script>

</body>
</html>
