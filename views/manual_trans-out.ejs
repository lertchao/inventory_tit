<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manual Issue Parts</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="icon" href="/images/storage.png" sizes="32x32">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet"/>

  <style>
    .print-actions {
      display: none;
    }
    .print-preview-card {
      display: none;
    }
    .table-sm td, .table-sm th {
      vertical-align: middle;
    }
  </style>
</head>

<body>
  <div class="container-fluid">
    <div class="row">
      <div class="desktop-sidebar col-lg-2 col-12 d-none d-lg-block">
        <%- include('sidebar') %>
      </div>

      <%- include('sidebarMobile') %>

      <div class="col-lg-10 col-12">
        <div class="d-flex justify-content-between align-items-center p-4 flex-wrap gap-2">
          <h2 class="text-danger m-0">
            Manual Issue Parts
            <img src="/images/out-of-stock.png" alt="logo" class="img-fluid" style="max-width: 40px; vertical-align: middle;">
          </h2>

          <div class="d-flex gap-2">
            <a href="/trans-out" class="btn btn-outline-secondary">
              <i class="bi bi-arrow-left"></i> Back to Issue Parts
            </a>
          </div>
        </div>

        <div id="status-banner" class="alert d-none mt-2"></div>

        <form id="manualIssueForm">
          <div class="row">
            <div class="mb-3 col-md-4 col-sm-12">
              <label class="form-label">เลขที่ใบเบิก</label>
              <input type="text" class="form-control text-center bg-light" id="manualRequestId" name="repair" readonly>
            </div>

            <div class="mb-3 col-md-4 col-sm-12">
              <label class="form-label">ชื่อผู้เบิก</label>
              <select class="select2" id="requesterName" name="name" required tabindex="0">
                <option value="" disabled selected>กรุณาเลือกชื่อผู้เบิก</option>
              </select>
            </div>

            <div class="mb-3 col-md-4 col-sm-12">
              <label class="form-label">สถานะใบงาน</label>
              <select class="form-select text-center" name="workStatus" required>
                <option value="Finish">Finish</option>
                <option value="Pending" selected>Pending</option>
              </select>
            </div>

            <div class="mb-3 col-md-3 col-sm-12">
              <label class="form-label">รหัสสาขา</label>
              <input type="text" class="form-control text-center" id="storeId" placeholder="กรุณากรอก รหัสสาขา" name="storeId" required>
            </div>

            <div class="mb-3 col-md-4 col-sm-12">
              <label class="form-label">ชื่อสาขา</label>
              <input type="text" class="form-control" id="storename" readonly>
            </div>
          </div>

          <div class="row mt-4">
            <div class="col-6">
              <h4>รายการสินค้าที่จ่ายออก</h4>
            </div>
            <div class="col-6 d-flex justify-content-end mb-3">
              <button type="button" class="btn btn-primary add-row">เพิ่มแถว</button>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table-bordered form_out">
              <thead>
                <tr class="table-dark">
                  <th class="text-center col-sm-2">รหัสสินค้า</th>
                  <th class="text-center col-sm-4">Description</th>
                  <th class="text-center col-1">จำนวน</th>
                  <th class="text-center col-1">Cost</th>
                  <th class="text-center col-1">การดำเนินการ</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>
                    <input type="text" class="form-control sku-input" placeholder="กรอกรหัสสินค้า" name="sku" required>
                  </td>
                  <td class="text-start description-cell align-middle"></td>
                  <td>
                    <input type="number" class="form-control text-center" placeholder="กรอกจำนวน" name="quantity" value="1" min="1" required>
                  </td>
                  <td class="text-center cost-cell align-middle"></td>
                  <td class="text-center">
                    <button type="button" class="btn btn-danger btn-sm remove-row">ลบ</button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>

          <button type="submit" class="btn btn-success mt-3">บันทึกข้อมูล</button>
        </form>

        <div id="alert-container" class="mt-3"></div>

        <div id="printActions" class="print-actions mt-4">
          <div class="d-flex gap-2 flex-wrap">
            <button type="button" id="printSlipBtn" class="btn btn-primary">
              <i class="bi bi-printer"></i> Print ใบจ่ายอะไหล่
            </button>
            <button type="button" id="newDocBtn" class="btn btn-outline-success">
              <i class="bi bi-plus-circle"></i> ทำรายการใหม่
            </button>
          </div>
        </div>

        <div id="printPreviewCard" class="card mt-4 print-preview-card">
          <div class="card-header fw-bold">Preview สำหรับพิมพ์</div>
          <div class="card-body" id="printPreviewContent"></div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/dayjs.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/plugin/timezone.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/dayjs@1/plugin/utc.js"></script>

  <script>
    dayjs.extend(dayjs_plugin_utc);
    dayjs.extend(dayjs_plugin_timezone);
  </script>

  <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

  <script>
    $(document).ready(function () {
      $('#requesterName').select2({
        theme: 'bootstrap-5',
        placeholder: 'กรุณาเลือกชื่อผู้เบิก',
        allowClear: true,
        width: '100%',
        minimumResultsForSearch: 0,
        ajax: {
          url: '/api/requesters',
          dataType: 'json',
          delay: 250,
          data: function (params) {
            return {
              q: params.term || '',
              active: true,
              format: 'select2',
              page: params.page || 1,
              limit: 20
            };
          },
          processResults: function (data) {
            const results = (data.results || []).map(it => ({
              id: it.text,
              text: it.text
            }));
            return {
              results,
              pagination: data.pagination || { more: false }
            };
          },
          cache: true
        }
      });

      $('#requesterName').on('keypress', function (e) {
        if (e.which === 13) e.preventDefault();
      });
    });
  </script>

  <script src="/js/manual_form_out.js"></script>
</body>
</html>